
//Faça um algoritmo para calcular a área de um cone(pi*r*h)

programa {
  funcao inicio() {

    real ar, r, hei, pi

    pi = 3.14

    escreva("Programa para calcular a área de um cone! :) \n")

    escreva("Digite a altura do cone: ")
    leia(hei)

    escreva("Digite o raio do cone: ")
    leia(r)

    ar = pi*r*hei

    escreva("A área do cone é de: ", ar)

  } 
}
