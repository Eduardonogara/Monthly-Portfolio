
//Faça um algoritmo para calcular a área superficial de um cilindro (2*pi*r*h)

programa {
  funcao inicio() {

  real r, pi, hei, ar

  pi = 3.14

  escreva("Programa para calcular a área superficial de um cilindro! :) \n")    

  escreva("Para começarmos, digite a altura do cilindro: ")
  leia(hei)

  escreva("Agora, digite o raio do cilindro: ")
  leia(r)

  ar = (2*pi*r*hei)

  escreva("A área superficial do cilindro é de ", ar)



  }
}
