programa {
  funcao inicio() {

    inteiro i = 0
    inteiro x

    para(i = 0; i <=5; i++){

      escreva("Digite um numero:")
      leia(x)

      se(x % 2 == 0){

        escreva("Esse numero é par \n")

        }
      senao{

        escreva("Esse numero é impar \n")

      }
      }
    }
  }
}
