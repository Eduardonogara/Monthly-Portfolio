programa {
  funcao inicio() {
   
    cadeia name

    inteiro age

    real wei

    escreva("Precisarei de algumas informações suas.\n")
   
    escreva("Digite seu nome: ")
    leia(name)
    
    escreva("Digite sua idade: ")
    leia(age)
   
    escreva("Digite seu peso: ")
    leia(wei)

    escreva("As informações digitadas foram:\n-- ",name ,"\n-- " ,age ,"\n-- ", wei)
    
  }
}
