programa {
  funcao inicio() {
    
    real n1, n2, media
    
    escreva("Algoritmo de cálculo de média entre duas notas.\n")

    escreva("Digite a primeira nota: ")
    leia(n1)
    
    escreva("Digite a segunda nota: ")
    leia(n2)

    media = (n1 + n2) /2
    
    escreva("A média das duas notas ficou: ", media)
    
  }
}
